@echo off
REM ============================================
REM   停止 auto_sync 后台守护进程
REM ============================================
chcp 65001 >nul
title auto_sync 停止器

cd /d "%~dp0"

echo.
echo ============================================
echo   auto_sync - 停止守护进程
echo ============================================
echo.

python -m auto_sync stop

echo.
echo ============================================
echo   完成
echo ============================================
timeout /t 3 /nobreak >nul